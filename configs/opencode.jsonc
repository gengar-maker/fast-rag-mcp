{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "blazing-code-rag": {
      "type": "local",
      "command": ["uv", "--directory", "/ABS/PATH/TO/blazing-rag-mcp", "run", "brag-mcp"],
      "enabled": true,
      "timeout": 10000,
      "environment": {
        "BRAG_ROOTS": "/ABS/PATH/TO/YOUR/REPO",
        "BRAG_DB_DIR": "/ABS/PATH/TO/YOUR/REPO/.brag",
        "BRAG_DEVICE": "auto",
        "BRAG_FAISS_GPU": "true",
        "BRAG_VECTOR_BACKEND": "auto",
        "BRAG_TORCH_VECTOR_DEVICE": "auto",
        "BRAG_EMBEDDING_MODEL": "Qwen/Qwen3-Embedding-0.6B",
        "BRAG_ALLOW_REINDEX_TOOL": "false"
      }
    }
  }
}
