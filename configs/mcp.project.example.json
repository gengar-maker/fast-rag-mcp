{
  "mcpServers": {
    "blazing-code-rag": {
      "type": "stdio",
      "command": "uv",
      "args": ["--directory", "/ABS/PATH/TO/blazing-rag-mcp", "run", "brag-mcp"],
      "env": {
        "BRAG_ROOTS": "${CLAUDE_PROJECT_DIR:-.}",
        "BRAG_DB_DIR": "${CLAUDE_PROJECT_DIR:-.}/.brag",
        "BRAG_DEVICE": "auto",
        "BRAG_FAISS_GPU": "true",
        "BRAG_VECTOR_BACKEND": "auto",
        "BRAG_TORCH_VECTOR_DEVICE": "auto",
        "BRAG_EMBEDDING_MODEL": "Qwen/Qwen3-Embedding-0.6B",
        "BRAG_ALLOW_REINDEX_TOOL": "false"
      }
    }
  }
}
