# Required
BRAG_ROOTS=/absolute/path/to/repository
BRAG_DB_DIR=/absolute/path/to/repository/.brag

# M3 Pro 36 GB balanced profile
BRAG_DEVICE=mps
BRAG_EMBEDDING_MODEL=nomic-ai/CodeRankEmbed
HF_HOME=~/.cache/blazing-rag/huggingface
SENTENCE_TRANSFORMERS_HOME=~/.cache/blazing-rag/sentence-transformers
BRAG_EMBEDDING_CACHE_DIR=~/.cache/blazing-rag/sentence-transformers
# Pin a reviewed Hugging Face commit hash before production deployment.
BRAG_EMBEDDING_REVISION=3c4b60807d71f79b43f3c4363786d9493691f8b1
BRAG_EMBEDDING_TRUST_REMOTE_CODE=true
BRAG_EMBEDDING_LOCAL_FILES_ONLY=false
BRAG_EMBEDDING_ALLOW_HASH_FALLBACK=false
BRAG_EMBEDDING_PRECISION=float16
BRAG_EMBEDDING_BATCH_SIZE=32
BRAG_EMBEDDING_FLUSH_CHUNKS=1024
BRAG_EMBEDDING_MAX_SEQ_LENGTH=384
BRAG_EMBEDDING_EMPTY_CACHE_AFTER_ENCODE=false
BRAG_EMBEDDING_REUSE_UNCHANGED_CHUNKS=true
BRAG_MPS_ENABLE_FALLBACK=false

BRAG_TOKENIZER_PARALLELISM=true
BRAG_TOKENIZER_THREADS=8
TOKENIZERS_PARALLELISM=true
RAYON_NUM_THREADS=8
HF_HUB_DISABLE_PROGRESS_BARS=1

# Scanner/chunker
BRAG_SCAN_BACKEND=auto
BRAG_FAST_STAT_SKIP=true
BRAG_DELETE_MISSING_ON_INCOMPLETE_SCAN=false
BRAG_MAX_FILE_BYTES=750000
BRAG_MAX_FILES=250000
BRAG_MAX_TARGETED_PATHS=256
BRAG_CHUNK_TOKENS=384
BRAG_CHUNK_OVERLAP=32
BRAG_MIN_CHUNK_CHARS=80
BRAG_ADD_FILE_SUMMARY_CHUNKS=false

# Dense retrieval. Auto keeps small matrices on NumPy/Accelerate.
BRAG_VECTOR_BACKEND=auto
BRAG_VECTOR_STORAGE_DTYPE=float16
BRAG_TORCH_VECTOR_DEVICE=mps
BRAG_TORCH_VECTOR_DTYPE=float16
BRAG_MPS_VECTOR_MIN_VECTORS=30000
BRAG_FAISS_GPU=false
BRAG_KEEP_CPU_VECTOR_COPY=false
BRAG_VECTOR_LOAD_BATCH_SIZE=8192

# SQLite
BRAG_SQLITE_TIMEOUT_SECONDS=30
BRAG_SQLITE_BUSY_TIMEOUT_MS=30000
BRAG_SQLITE_CACHE_KIB=131072
BRAG_SQLITE_MMAP_BYTES=268435456

# Safe MCP defaults. CLI indexing is still permitted.
BRAG_READ_ONLY=true
BRAG_ALLOW_REINDEX_TOOL=false
BRAG_LOG_LEVEL=INFO
